{
  "changelog": {
    "exclude": {
      "labels": ["skip-changelog"]
    },
    "categories": [
      {
        "title": "## 🚀 Features",
        "labels": ["feature", "enhancement", "Feature Request"]
      },
      {
        "title": "## 🐛 Bug Fixes",
        "labels": ["bug", "fix"]
      },
      {
        "title": "## 🔧 Continuous Integration",
        "labels": ["Continuous Delivery", "ci"]
      },
      {
        "title": "## 🧪 Tests",
        "labels": ["test", "Chore"]
      },
      {
        "title": "## 📦 Dependencies",
        "labels": ["dependencies"]
      },
      {
        "title": "## 📝 Other Changes",
        "labels": ["*"]
      }
    ]
  }
}
